# ======================================================================
# 应用基础配置
# ======================================================================
# 运行环境：development / production / test
NODE_ENV=development

# 服务监听端口
PORT=8000

# ======================================================================
# 数据库
# ======================================================================
# MySQL 连接串，格式: mysql://USER:PASSWORD@HOST:PORT/DB_NAME?参数
# 本地开发可用：mysql://root:root@localhost:3306/nestjs_starter
DATABASE_URL=mysql://root:root@localhost:3306/nestjs_starter

# ======================================================================
# JWT
# ======================================================================
# JWT 签名密钥，生产环境必须使用强随机字符串（至少 32 字符）
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production-use-a-strong-random-secret
# JWT 过期时间，支持 zeit/ms 格式: 60, "2 days", "10h", "7d"
JWT_EXPIRES_IN=7d

# ======================================================================
# CORS
# ======================================================================
# 允许的跨域来源，多个用逗号分隔。开发环境用 * 允许所有
CORS_ORIGIN=*

# ======================================================================
# 日志
# ======================================================================
# 日志级别: error / warn / info / debug
LOG_LEVEL=debug
